---
import config from '../../site.json';
const year = new Date().getFullYear();
---
<footer class="bg-base-200 border-t border-base-300/50">
  <div class="container mx-auto px-6 lg:px-12 py-16">
    <div class="grid md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <h3 class="text-2xl font-heading font-bold mb-4">
          <span class="text-accent">{config.business_name.split(' ')[0]}</span> {config.business_name.split(' ').slice(1).join(' ')}
        </h3>
        <p class="text-base-content/60 max-w-sm">{config.description}</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-heading font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2 text-base-content/60">
          <li><a href="#roster" class="hover:text-accent transition-colors">Roster</a></li>
          <li><a href="#schedule" class="hover:text-accent transition-colors">Schedule</a></li>
          <li><a href="#stats" class="hover:text-accent transition-colors">Stats</a></li>
          <li><a href="#about" class="hover:text-accent transition-colors">About</a></li>
        </ul>
      </div>

      <!-- More -->
      <div>
        <h4 class="font-heading font-semibold mb-4">More</h4>
        <ul class="space-y-2 text-base-content/60">
          <li><a href="#registration" class="hover:text-accent transition-colors">Registration</a></li>
          <li><a href="#contact" class="hover:text-accent transition-colors">Contact</a></li>
          <li><a href="#" class="hover:text-accent transition-colors">Privacy Policy</a></li>
          <li><a href="#" class="hover:text-accent transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="divider my-8"></div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-base-content/50">
      <p>&copy; {year} {config.business_name}. All rights reserved.</p>
      <p>
        Built by <a href={config.built_by.url} target="_blank" rel="noopener" class="text-accent hover:underline">{config.built_by.name}</a>
      </p>
    </div>
  </div>
</footer>
