---
import config from '../../site.json';
---
<section class="min-h-[90vh] flex items-center pt-16">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text -->
      <div class="fade-in-up">
        <span class="badge badge-accent badge-lg text-xs tracking-widest uppercase font-bold mb-4">AAU Basketball</span>
        <h1 class="text-5xl md:text-7xl font-heading font-bold uppercase leading-none mb-6">
          {config.tagline.split('.')[0]}<span class="text-accent">.</span>
          <br />
          <span class="text-base-content/60">{config.tagline.split('.').slice(1).join('.').trim()}</span>
        </h1>
        <p class="text-lg text-base-content/70 max-w-md mb-8">
          {config.description}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#registration" class="btn btn-accent btn-lg px-10 uppercase font-bold tracking-wide">
            Register for Tryouts
          </a>
          <a href="#roster" class="btn btn-outline btn-lg px-8 uppercase font-bold tracking-wide">
            Meet the Team
          </a>
        </div>
      </div>

      <!-- Right: Basketball action image -->
      <div class="fade-in-up relative" style="animation-delay: 0.3s;">
        <div class="relative aspect-square max-w-lg mx-auto">
          <!-- Accent glow behind image -->
          <div class="absolute inset-0 bg-accent/10 rounded-3xl blur-3xl"></div>
          <div class="relative bg-base-200 rounded-3xl overflow-hidden aspect-square border-2 border-accent/20">
            <img src="https://images.unsplash.com/photo-1546519638-68e109498ffc?w=800&h=800&fit=crop" alt="Basketball action" class="w-full h-full object-cover" />
          </div>
          <!-- Floating stats badges -->
          <div class="absolute -bottom-4 -left-4 bg-base-200 border border-base-300/50 rounded-2xl p-4 shadow-xl">
            <p class="text-xs text-base-content/60 uppercase tracking-wider font-bold">Season Record</p>
            <p class="text-3xl font-heading font-bold text-accent">{config.stats.record}</p>
          </div>
          <div class="absolute -top-4 -right-4 bg-base-200 border border-base-300/50 rounded-2xl p-4 shadow-xl">
            <p class="text-xs text-base-content/60 uppercase tracking-wider font-bold">Tournament Wins</p>
            <p class="text-3xl font-heading font-bold text-accent">{config.stats.tournament_wins}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
