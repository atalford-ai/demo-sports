---
import config from '../../site.json';
const stats = config.stats;
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Basketball court background image with dark overlay -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1505666287802-931dc83948e5?w=1920&h=1080&fit=crop"
      alt="Basketball court"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-base-100/80 via-base-100/60 to-base-100/90"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-6 lg:px-12 py-32">
    <div class="flex flex-col items-center text-center">
      <!-- Floating stat boxes -->
      <div class="w-full flex flex-wrap justify-center gap-4 mb-12">
        <div class="stats shadow bg-base-100/80 backdrop-blur-sm">
          <div class="stat">
            <div class="stat-title">Season Record</div>
            <div class="stat-value text-accent">{stats.record}</div>
            <div class="stat-desc">Current season</div>
          </div>
        </div>
        <div class="stats shadow bg-base-100/80 backdrop-blur-sm">
          <div class="stat">
            <div class="stat-title">Points Per Game</div>
            <div class="stat-value text-accent">{stats.points_per_game}</div>
            <div class="stat-desc">Team average</div>
          </div>
        </div>
        <div class="stats shadow bg-base-100/80 backdrop-blur-sm">
          <div class="stat">
            <div class="stat-title">Tournament Wins</div>
            <div class="stat-value text-accent">{stats.tournament_wins}</div>
            <div class="stat-desc">This year</div>
          </div>
        </div>
      </div>

      <!-- Headline -->
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-heading font-bold uppercase leading-none mb-6 tracking-tight">
        {config.business_name}
      </h1>
      <p class="text-xl md:text-2xl text-base-content/70 font-heading uppercase tracking-widest mb-4">
        {config.tagline}
      </p>
      <p class="text-base-content/60 max-w-xl mb-10">
        {config.description}
      </p>

      <!-- CTA -->
      <a href="#registration" class="btn btn-accent btn-lg px-12 uppercase font-bold tracking-wide text-lg shadow-lg">
        Register for Tryouts
      </a>
    </div>
  </div>
</section>
