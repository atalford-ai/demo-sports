---
import config from '../../site.json';
const reg = config.registration;
---
<section id="registration" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto max-w-4xl">
    <div class="text-center mb-12">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Join the Team</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Tryout Registration</h2>
      <p class="text-base-content/60 mt-4 max-w-lg mx-auto">Ready to compete? Register for upcoming tryouts and take your game to the next level.</p>
    </div>

    <!-- Steps component showing registration process -->
    <ul class="steps steps-horizontal w-full mb-16">
      <li class="step step-accent">Fill Info</li>
      <li class="step step-accent">Select Age Group</li>
      <li class="step">Pay</li>
      <li class="step">Show Up</li>
    </ul>

    <!-- Registration form with fieldset grouping -->
    <div class="bg-base-200 rounded-2xl p-8 shadow-lg">
      <form class="space-y-8">
        <!-- Player Info fieldset -->
        <fieldset class="border border-base-300 rounded-xl p-6">
          <legend class="text-sm font-heading font-semibold uppercase tracking-wider px-2">Player Information</legend>
          <div class="space-y-4 mt-4">
            <div>
              <label class="label text-sm font-medium">Player Name</label>
              <input type="text" placeholder="Player's full name" class="input input-bordered w-full bg-base-100 focus:border-accent" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="label text-sm font-medium">Age</label>
                <input type="number" placeholder="Age" min="8" max="18" class="input input-bordered w-full bg-base-100 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Position</label>
                <select class="select select-bordered w-full bg-base-100 focus:border-accent">
                  <option disabled selected>Select position</option>
                  <option>Point Guard</option>
                  <option>Shooting Guard</option>
                  <option>Small Forward</option>
                  <option>Power Forward</option>
                  <option>Center</option>
                </select>
              </div>
            </div>
            <div>
              <label class="label text-sm font-medium">Age Group</label>
              <div class="flex flex-wrap gap-2">
                {reg.age_groups.map((group: string) => (
                  <label class="cursor-pointer">
                    <input type="radio" name="age_group" class="radio radio-accent radio-sm hidden peer" />
                    <span class="badge badge-lg badge-outline peer-checked:badge-accent cursor-pointer">{group}</span>
                  </label>
                ))}
              </div>
            </div>
          </div>
        </fieldset>

        <!-- Parent Info fieldset -->
        <fieldset class="border border-base-300 rounded-xl p-6">
          <legend class="text-sm font-heading font-semibold uppercase tracking-wider px-2">Parent / Guardian</legend>
          <div class="space-y-4 mt-4">
            <div>
              <label class="label text-sm font-medium">Full Name</label>
              <input type="text" placeholder="Parent/Guardian name" class="input input-bordered w-full bg-base-100 focus:border-accent" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="label text-sm font-medium">Email</label>
                <input type="email" placeholder="you@email.com" class="input input-bordered w-full bg-base-100 focus:border-accent" />
              </div>
              <div>
                <label class="label text-sm font-medium">Phone</label>
                <input type="tel" placeholder="(555) 123-4567" class="input input-bordered w-full bg-base-100 focus:border-accent" />
              </div>
            </div>
          </div>
        </fieldset>

        <!-- Tryout details -->
        <div class="bg-base-300/50 rounded-xl p-6">
          <div class="flex flex-wrap gap-8">
            <div>
              <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Tryout Dates</p>
              {reg.tryout_dates.map((date: string) => (
                <p class="font-medium text-sm">{date}</p>
              ))}
            </div>
            <div>
              <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Location</p>
              <p class="font-medium text-sm">{reg.location}</p>
            </div>
            <div>
              <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Fee</p>
              <p class="font-medium text-sm text-accent text-lg">{reg.cost}</p>
            </div>
          </div>
        </div>

        <button type="submit" class="btn btn-accent btn-lg w-full uppercase font-bold tracking-wide">
          Submit Registration
        </button>
      </form>
    </div>
  </div>
</section>
