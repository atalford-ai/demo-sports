---
import config from '../../site.json';
const players = config.roster;
---
<section id="roster" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-12">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">The Squad</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Meet the Roster</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">The athletes putting in work every day to compete at the highest level.</p>
    </div>

    <!-- Horizontal scrolling carousel -->
    <div class="overflow-x-auto pb-6">
      <div class="flex flex-nowrap gap-6 min-w-max px-4">
        {players.map((player) => (
          <div class="card card-compact bg-base-200 shadow-md w-56 shrink-0 hover:shadow-xl transition-shadow duration-300">
            <figure class="relative h-64">
              <img
                src={player.image}
                alt={player.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <!-- Jersey number badge overlaid on image -->
              <div class="absolute top-3 right-3">
                <span class="badge badge-accent badge-lg text-lg font-bold">#{player.number}</span>
              </div>
            </figure>
            <div class="card-body">
              <h3 class="card-title text-base font-heading">{player.name}</h3>
              <p class="text-accent text-sm font-medium">{player.position}</p>
              <p class="text-base-content/50 text-xs">{player.grade} Grade</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <p class="text-center text-base-content/40 text-sm mt-4">Scroll to see all players &rarr;</p>
  </div>
</section>
