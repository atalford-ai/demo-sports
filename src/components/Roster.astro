---
import config from '../../site.json';
const players = config.roster;
---
<section id="roster" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">The Squad</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Meet the Roster</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">The athletes putting in work every day to compete at the highest level.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
      {players.map((player) => (
        <div class="card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <!-- Player Image -->
          <div class="relative aspect-square bg-base-300/50 overflow-hidden">
            <img src={player.image} alt={player.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <!-- Jersey Number Overlay -->
            <div class="absolute top-3 right-3">
              <span class="badge badge-accent text-lg font-bold px-3 py-3">#{player.number}</span>
            </div>
          </div>

          <div class="card-body p-5">
            <h3 class="font-heading font-semibold text-lg">{player.name}</h3>
            <div class="flex items-center justify-between">
              <span class="text-accent font-medium">{player.position}</span>
              <span class="text-sm text-base-content/50">{player.grade} Grade</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
