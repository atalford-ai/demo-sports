---
import config from '../../site.json';
const games = config.schedule;
---
<section id="schedule" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto max-w-4xl">
    <div class="text-center mb-12">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Upcoming</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Game Schedule</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">Check out where we're competing next.</p>
    </div>

    <div class="overflow-x-auto rounded-xl shadow-lg">
      <table class="table table-zebra w-full">
        <thead>
          <tr class="bg-base-300">
            <th class="font-heading text-sm uppercase tracking-wider">Date</th>
            <th class="font-heading text-sm uppercase tracking-wider">Time</th>
            <th class="font-heading text-sm uppercase tracking-wider">Opponent</th>
            <th class="font-heading text-sm uppercase tracking-wider">Venue</th>
            <th class="font-heading text-sm uppercase tracking-wider text-center">Status</th>
          </tr>
        </thead>
        <tbody>
          {games.map((game) => (
            <tr class="hover">
              <td class="font-medium whitespace-nowrap">
                {new Date(game.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </td>
              <td class="whitespace-nowrap">{game.time}</td>
              <td class="font-semibold">{game.opponent}</td>
              <td class="text-base-content/70 text-sm">{game.location}</td>
              <td class="text-center">
                {game.home_away === 'Home' ? (
                  <span class="badge badge-success gap-1">Home</span>
                ) : (
                  <span class="badge badge-warning gap-1">Away</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
