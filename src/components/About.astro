---
import config from '../../site.json';
---
<section id="about" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto max-w-4xl">
    <div class="text-center mb-12">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Our Story</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Built on the Hardwood</h2>
    </div>

    <!-- Card with image-full: full-bleed team photo with text overlay -->
    <div class="card image-full shadow-xl">
      <figure>
        <img
          src="https://images.unsplash.com/photo-1526232761682-d26e03ac148e?w=1200&h=600&fit=crop"
          alt="Team huddle"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </figure>
      <div class="card-body justify-end">
        <p class="text-lg leading-relaxed mb-4">
          Elite Hoops was founded with one mission: to develop young athletes who excel both on the court and in life. Based in Atlanta, we bring together the best coaching staff, elite competition, and a family-first culture that pushes every player to reach their potential.
        </p>
        <p class="text-base leading-relaxed mb-6 opacity-80">
          Our coaching staff brings decades of experience from college and professional basketball. We focus on fundamentals, basketball IQ, and the discipline that translates beyond the game. This is more than a team — it's a program.
        </p>
        <div class="card-actions justify-start">
          <div class="stats bg-base-100/20 backdrop-blur-sm shadow">
            <div class="stat px-4 py-2">
              <div class="stat-value text-lg">{config.stats.players_developed}</div>
              <div class="stat-desc">Athletes</div>
            </div>
            <div class="stat px-4 py-2">
              <div class="stat-value text-lg">{config.stats.tournament_wins}</div>
              <div class="stat-desc">Titles</div>
            </div>
            <div class="stat px-4 py-2">
              <div class="stat-value text-lg">{config.stats.years_active}</div>
              <div class="stat-desc">Years</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
